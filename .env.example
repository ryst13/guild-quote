# Database
DATABASE_URL=./data/guildquote.db

# Public URL
BASE_URL=http://localhost:5173

# SMTP (leave blank to skip email sending in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Resend (optional)
RESEND_API_KEY=

# Magic link
MAGIC_LINK_EXPIRY_MINUTES=15

# Node env
NODE_ENV=development
