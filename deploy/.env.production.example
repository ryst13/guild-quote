# ── GuildQuote PRODUCTION environment ──────────────────────────────────────
# These become Fly secrets (`fly secrets set KEY=value`), NOT a committed file.
# Placeholders only. Fill the blanks at launch (LR-2).

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_URL=/app/data/guildquote.db          # on the Fly volume
ORIGIN=https://guildquote.com                 # adapter-node CSRF + URLs
BASE_URL=https://guildquote.com
PUBLIC_BASE_URL=https://guildquote.com
BODY_SIZE_LIMIT=8M                            # logo uploads are 2MB
MAGIC_LINK_EXPIRY_MINUTES=15
# (ORIGIN/BASE_URL/PORT/DATABASE_URL/BODY_SIZE_LIMIT are already in fly.toml
#  [env]; only the SECRETS below must be set via `fly secrets set`.)

# ── Google OAuth (Drive + Docs scopes only) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://guildquote.com/auth/google/callback

# ── Email — Resend over SMTP ────────────────────────────────────────────────
# SMTP_USER is the literal word "resend"; SMTP_PASS is your Resend API key.
# SMTP_SENDER must be on a Resend-verified domain.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_SENDER=estimates@guildquote.com
SMTP_FROM="GuildQuote <estimates@guildquote.com>"

# ── Stripe (LIVE keys at launch) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GQ_MONTHLY=price_...             # $49 product
STRIPE_PRICE_PRO_MONTHLY=price_...            # $129 product
STRIPE_PRICE_GQ_YEARLY=                       # optional — no annual UI today
STRIPE_PRICE_PRO_YEARLY=                      # optional

# ── Litestream backup (S3-compatible) ───────────────────────────────────────
LITESTREAM_REPLICA_URL=s3://guildquote-backups/db
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev   # Tigris/B2; omit for AWS

# ── Optional ────────────────────────────────────────────────────────────────
# SENTRY_DSN=
